---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  pageClass?: string;
}

const { title = '寶得利國際', pageClass = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="寶得利國際股份有限公司 — 珠寶零售、觀光旅遊及國際貿易" />
    <link rel="icon" type="image/x-icon" href={`${base}images/favicon.ico`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="font-sans text-gray-800">
    <!-- Loading -->
    <div
      id="loading"
      class="fixed inset-0 z-[9999] bg-primary flex items-center justify-center transition-opacity duration-500"
    >
      <div class="text-gold text-2xl font-serif tracking-widest">Loading<span class="animate-pulse">...</span></div>
    </div>

    <div id="wrapper" class={pageClass}>
      <Header />
      <slot />
      <Footer />
    </div>

    <script>
      window.addEventListener('load', () => {
        const loading = document.getElementById('loading');
        if (loading) {
          loading.style.opacity = '0';
          setTimeout(() => {
            loading.style.display = 'none';
          }, 500);
        }
      });

      // Language switching
      document.querySelectorAll('.lang-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const lang = btn.dataset.lang;
          localStorage.setItem('cjw_lang', lang);
          document.querySelectorAll('.lang-btn').forEach((b) => {
            b.classList.toggle('text-gold', b.dataset.lang === lang);
            b.classList.toggle('border-gold', b.dataset.lang === lang);
            b.classList.toggle('active', b.dataset.lang === lang);
            b.classList.toggle('text-white/60', b.dataset.lang !== lang);
            b.classList.toggle('border-white/30', b.dataset.lang !== lang);
          });
          // Dispatch custom event for pages that support language switching
          window.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
        });
      });

      // Restore language preference
      const savedLang = localStorage.getItem('cjw_lang');
      if (savedLang && savedLang !== 'tw') {
        document.querySelector(`.lang-btn[data-lang="${savedLang}"]`)?.click();
      }
    </script>
  </body>
</html>
