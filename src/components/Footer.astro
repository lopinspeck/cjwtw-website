---
import { langData, aboutData, comData } from '../data/lang.js';
const base = import.meta.env.BASE_URL;
---

<footer class="bg-primary text-white">
  <!-- Back to top -->
  <button id="top-btn" class="fixed bottom-6 right-6 z-40 w-12 h-12 bg-gold text-primary rounded-full shadow-lg flex items-center justify-center text-xs font-bold opacity-0 invisible transition-all hover:bg-gold/90" aria-label="回到頂部">
    TOP
  </button>

  <div class="max-w-7xl mx-auto px-4 py-12">
    <!-- Logo -->
    <a href={base} class="inline-block mb-8">
      <img src={`${base}images/logo_f.svg`} alt="寶得利國際" class="h-10" />
    </a>

    <!-- Sitemap -->
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-6 mb-10 text-sm">
      <!-- 關於寶得利 -->
      <div>
        <h3 class="text-gold font-bold mb-3">{langData[2].tw}</h3>
        <div class="space-y-2">
          <a href={`${base}about/2`} class="block text-white/60 hover:text-gold transition-colors">{aboutData[2].tw}</a>
          <a href={`${base}about/7`} class="block text-white/60 hover:text-gold transition-colors">{aboutData[7].tw}</a>
          <a href={`${base}about/4`} class="block text-white/60 hover:text-gold transition-colors">{aboutData[4].tw}</a>
          <a href={`${base}about/5`} class="block text-white/60 hover:text-gold transition-colors">{aboutData[5].tw}</a>
        </div>
      </div>

      <!-- 投資人專區 -->
      <div>
        <h3 class="text-gold font-bold mb-3">{langData[3].tw}</h3>
        <div class="space-y-2">
          <a href={`${base}financial`} class="block text-white/60 hover:text-gold transition-colors">{langData[4].tw}</a>
          <a href={`${base}investor`} class="block text-white/60 hover:text-gold transition-colors">{langData[5].tw}</a>
          <a href={`${base}investor-info`} class="block text-white/60 hover:text-gold transition-colors">{langData[6].tw}</a>
        </div>
      </div>

      <!-- 公司治理 -->
      <div>
        <h3 class="text-gold font-bold mb-3">{langData[7].tw}</h3>
        <div class="space-y-2">
          {Object.entries(comData).map(([id, val]) => (
            <a href={`${base}company/${id}`} class="block text-white/60 hover:text-gold transition-colors">{val.tw}</a>
          ))}
        </div>
      </div>

      <!-- 新消息 -->
      <div>
        <h3 class="text-gold font-bold mb-3"><a href={`${base}news`} class="hover:text-gold">{langData[8].tw}</a></h3>
      </div>

      <!-- 關係企業 -->
      <div>
        <h3 class="text-gold font-bold mb-3"><a href={`${base}group`} class="hover:text-gold">{langData[9].tw}</a></h3>
      </div>

      <!-- 企業社會責任 -->
      <div>
        <h3 class="text-gold font-bold mb-3">{langData[10].tw}</h3>
        <div class="space-y-2">
          <a href={`${base}hr`} class="block text-white/60 hover:text-gold transition-colors">{langData[11].tw}</a>
          <a href={`${base}career`} class="block text-white/60 hover:text-gold transition-colors">{langData[12].tw}</a>
          <a href={`${base}csr-report`} class="block text-white/60 hover:text-gold transition-colors">{langData[13].tw}</a>
        </div>
      </div>

      <!-- 影音專區 -->
      <div>
        <h3 class="text-gold font-bold mb-3"><a href={`${base}video`} class="hover:text-gold">{langData[14].tw}</a></h3>
      </div>

      <!-- 聯絡我們 -->
      <div>
        <h3 class="text-gold font-bold mb-3"><a href={`${base}contact`} class="hover:text-gold">{langData[15].tw}</a></h3>
      </div>
    </div>

    <!-- Contact info -->
    <div class="border-t border-white/10 pt-6 flex flex-col md:flex-row md:items-center gap-4 text-sm text-white/50">
      <a href="https://maps.google.com.tw/maps?q=台北市中山區新生北路二段28巷1號B1" target="_blank" class="hover:text-gold transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        {langData[16].tw}
      </a>
      <a href="mailto:ning@cjwtaiwan.com" class="hover:text-gold transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        ning@cjwtaiwan.com
      </a>
      <a href="tel:02-8921-1333#788" class="hover:text-gold transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
        02-8921-1333#788
      </a>
    </div>

    <div class="text-center text-white/30 text-xs mt-6">
      &copy; {new Date().getFullYear()} 寶得利國際股份有限公司 All Rights Reserved.
    </div>
  </div>
</footer>

<script>
  const topBtn = document.getElementById('top-btn');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      topBtn?.classList.remove('opacity-0', 'invisible');
      topBtn?.classList.add('opacity-100', 'visible');
    } else {
      topBtn?.classList.add('opacity-0', 'invisible');
      topBtn?.classList.remove('opacity-100', 'visible');
    }
  });
  topBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
