---
interface Props {
  titleEn: string;
  titleTw: string;
}

const { titleEn, titleTw } = Astro.props;
---

<div class="relative bg-primary py-16 lg:py-24 flex items-center justify-center">
  <div class="absolute inset-0 bg-gradient-to-b from-primary/80 to-primary"></div>
  <div class="relative text-center">
    <h1 class="font-serif text-gold text-3xl lg:text-5xl tracking-wider mb-2">{titleEn}</h1>
    <h2 class="text-white/80 text-lg lg:text-xl tracking-widest">{titleTw}</h2>
  </div>
</div>
