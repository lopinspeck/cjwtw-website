---
import SubPageLayout from '../components/SubPageLayout.astro';
import { groupData } from '../data/lang.js';
import { decodeHtml } from '../data/decode.js';
import pagesData from '../data/pages.json';

const base = import.meta.env.BASE_URL;
const menuItems = Object.entries(groupData).map(([key, val]) => ({
  id: key,
  label: val.tw,
  href: `${base}group?id=${key}`,
}));

const pageContent = pagesData['group.html'];
const contentHtml = pageContent ? decodeHtml(pageContent.g_text_tw) : '';
---

<SubPageLayout
  title="йЧЬдњВдЉБж•≠"
  titleEn="Affiliate Enterprise"
  titleTw="йЧЬдњВдЉБж•≠"
  menuItems={menuItems}
  activeId="1"
>
  <div set:html={contentHtml} />
</SubPageLayout>
