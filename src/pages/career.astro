---
import SubPageLayout from '../components/SubPageLayout.astro';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'hr', label: '人力資源', href: `${base}hr` },
  { id: 'career', label: '人才招募', href: `${base}career` },
  { id: 'csr-report', label: '報告書下載', href: `${base}csr-report` },
];
---

<SubPageLayout title="人才招募" titleEn="CSR" titleTw="企業社會責任" menuItems={menuItems} activeId="career">
  <h3 class="text-xl font-bold text-primary mb-4">加入寶得利</h3>
  <p class="mb-6 leading-relaxed">
    寶得利國際歡迎具有熱忱與專業能力的人才加入我們的團隊。我們提供多元的工作機會，橫跨珠寶零售、觀光旅遊及國際貿易等領域，讓您在國際化的舞台上展現才華。
  </p>

  <h3 class="text-xl font-bold text-primary mb-4">應徵方式</h3>
  <p class="mb-4 leading-relaxed">
    歡迎將您的履歷及相關作品寄至：
  </p>
  <p class="mb-6">
    <a href="mailto:ning@cjwtaiwan.com" class="text-gold hover:underline font-bold">ning@cjwtaiwan.com</a>
  </p>
  <p class="leading-relaxed text-gray-500">
    我們將在收到您的履歷後盡快與您聯繫，感謝您對寶得利的關注。
  </p>
</SubPageLayout>
