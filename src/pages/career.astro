---
import SubPageLayout from '../components/SubPageLayout.astro';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'hr', label: '人力資源', href: `${base}hr` },
  { id: 'career', label: '人才招募', href: `${base}career` },
  { id: 'csr-report', label: '報告書下載', href: `${base}csr-report` },
];
---

<SubPageLayout
  title="人才招募"
  titleEn="CSR"
  titleTw="企業社會責任"
  menuItems={menuItems}
  activeId="career"
>
  <p>111</p>
</SubPageLayout>
