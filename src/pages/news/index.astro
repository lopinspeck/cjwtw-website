---
import Layout from '../../layouts/Layout.astro';
import Banner from '../../components/Banner.astro';
import { newsData } from '../../data/lang.js';
const base = import.meta.env.BASE_URL;
---

<Layout title="新消息" pageClass="about_page">
  <Banner titleEn="NEWS" titleTw="新消息" />
  <main class="max-w-7xl mx-auto px-4 py-10 lg:py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        Object.entries(newsData).map(([id, item]) => (
          <a
            href={`${base}news/${id}`}
            class="group block bg-white rounded-lg shadow hover:shadow-xl transition-shadow overflow-hidden"
          >
            <div class="h-48 bg-primary/5 overflow-hidden">
              <img
                src={`${base}images/news_image.jpg`}
                alt={item.tw}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
            <div class="p-6">
              <h3 class="text-primary font-bold group-hover:text-gold transition-colors">{item.tw}</h3>
            </div>
          </a>
        ))
      }
    </div>
  </main>
</Layout>
