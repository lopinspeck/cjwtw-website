---
import SubPageLayout from '../../components/SubPageLayout.astro';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: '5', label: '寶得利子公司-完美比例與中國國際航空簽署貨運承攬業務', href: `${base}news/5` },
  { id: '1', label: '寶得利首間馬來西亞據點揭牌報導', href: `${base}news/1` },
  { id: '3', label: '金門高梁酒 限量優惠活動', href: `${base}news/3` },
];
---

<SubPageLayout title="金門高梁酒 限量優惠活動" titleEn="NEWS" titleTw="新消息" menuItems={menuItems} activeId="3">
  <article class="space-y-6">
    <img
      alt="金門高梁酒 限量優惠活動"
      src="/cjwtw-website/images/upload/2022_05_25_231700(1).jpg"
      class="w-full max-w-2xl rounded-lg"
    />

    <p class="text-base text-gray-700">
      <a
        href="http://www.cjwtaiwan.com/cjw_collection.html"
        target="_blank"
        class="inline-flex items-center gap-1 text-gold font-semibold hover:underline"
      >
        點我詳細介紹 &rarr;
      </a>
    </p>
  </article>
</SubPageLayout>
