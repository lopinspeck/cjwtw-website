---
import SubPageLayout from '../../components/SubPageLayout.astro';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: '5', label: '寶得利子公司-完美比例與中國國際航空簽署貨運承攬業務', href: `${base}news/5` },
  { id: '1', label: '寶得利首間馬來西亞據點揭牌報導', href: `${base}news/1` },
  { id: '3', label: '金門高梁酒 限量優惠活動', href: `${base}news/3` },
];
---

<SubPageLayout
  title="寶得利子公司-完美比例與中國國際航空簽署貨運承攬業務"
  titleEn="NEWS"
  titleTw="新消息"
  menuItems={menuItems}
  activeId="5"
>
  <p>
    <img alt="" src="/cjwtw-website/images/upload/2022_05_25_120119.jpg" style="height:284px; width:723px" /><img
      alt=""
      src="/cjwtw-website/images/upload/2022_05_25_231702(12).jpg"
      style="height:284px; width:723px"
    />
  </p>

  <p>
    因疫情期間海運塞港、缺工、缺櫃導致港口週轉率下率，再加上眾多產業的供應鍊受疫情影響、伴隨後疫情時代全球經濟持續復甦、空運需求增加、海運轉空運效益造成航空運價維持高水平，空運市場展望樂觀，寶得利將在既有觀光產業基礎上導入貨運承攬業務，其中持股100%子公司完美比例國際股份有限公司與大陸商中國國際航空股份有限公司於111年5月12日完成簽署貨運銷售代理協議，對雙方未來的營運均有正面的助益。
  </p>

  <p>圖片來源：https://www.airchina.com.tw</p>
</SubPageLayout>
