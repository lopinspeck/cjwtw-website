---
import Layout from '../layouts/Layout.astro';
import Banner from '../components/Banner.astro';
import { langData } from '../data/lang.js';
---

<Layout title="聯絡我們" pageClass="contact_page">
  <Banner titleEn="Contact" titleTw="聯絡我們" />
  <main class="max-w-7xl mx-auto px-4 py-10 lg:py-16">
    <!-- Company Info -->
    <div class="bg-primary text-white rounded-lg p-8 mb-10">
      <h2 class="text-xl font-bold text-gold mb-6">{langData[24].tw}</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
          >
          <div>
            <p class="text-gold text-sm font-bold mb-1">{langData[25].tw}</p>
            <p class="text-white/80 text-sm">{langData[26].tw}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg
          >
          <div>
            <p class="text-gold text-sm font-bold mb-1">{langData[27].tw}</p>
            <p class="text-white/80 text-sm">{langData[28].tw}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path></svg
          >
          <div>
            <p class="text-gold text-sm font-bold mb-1">{langData[29].tw}</p>
            <p class="text-white/80 text-sm">{langData[30].tw}</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-6 h-6 text-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path></svg
          >
          <div>
            <p class="text-gold text-sm font-bold mb-1">{langData[31].tw}</p>
            <p class="text-white/80 text-sm">{langData[32].tw}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="bg-white rounded-lg shadow-lg p-8">
      <h4 class="text-primary/60 mb-8">{langData[33].tw}</h4>
      <form id="contact-form" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-bold text-primary mb-2">{langData[34].tw}</label>
            <input
              type="text"
              name="company"
              placeholder={langData[35].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2"
              ><span class="text-red-500">*</span> {langData[36].tw}</label
            >
            <input
              type="text"
              name="name"
              required
              placeholder={langData[37].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2"
              ><span class="text-red-500">*</span> {langData[38].tw}</label
            >
            <input
              type="tel"
              name="tel"
              required
              placeholder={langData[39].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2">{langData[40].tw}</label>
            <input
              type="tel"
              name="phone"
              placeholder={langData[41].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2"
              ><span class="text-red-500">*</span> {langData[42].tw}</label
            >
            <input
              type="email"
              name="mail"
              required
              placeholder={langData[43].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
          <div>
            <label class="block text-sm font-bold text-primary mb-2">{langData[44].tw}</label>
            <input
              type="text"
              name="address"
              placeholder={langData[45].tw}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors"
            />
          </div>
        </div>
        <div>
          <label class="block text-sm font-bold text-primary mb-2">{langData[46].tw}</label>
          <textarea
            name="content"
            rows="5"
            placeholder={langData[47].tw}
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold focus:border-gold outline-none transition-colors resize-none"
          ></textarea>
        </div>
        <div class="text-center">
          <button
            type="submit"
            class="bg-primary text-white px-12 py-3 rounded-lg hover:bg-gold hover:text-primary transition-colors font-bold tracking-wider"
          >
            {langData[48].tw}
          </button>
        </div>
      </form>
    </div>
  </main>
</Layout>
