---
import SubPageLayout from '../components/SubPageLayout.astro';
import { langData } from '../data/lang.js';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'financial', label: langData[4].tw, href: `${base}financial` },
  { id: 'investor', label: langData[5].tw, href: `${base}investor` },
  { id: 'investor-info', label: langData[6].tw, href: `${base}investor-info` },
];
---

<SubPageLayout
  title="投資人資訊"
  titleEn="Investor Zone"
  titleTw="投資人專區"
  menuItems={menuItems}
  activeId="investor-info"
  pageClass="financial_page"
>
  <section class="mb-10">
    <h4 class="text-xl font-bold text-primary mb-4 border-b border-gold/30 pb-2">投資人服務</h4>
    <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-base">
      <dt class="font-semibold text-gray-600">掛牌交易</dt>
      <dd>中華民國證券櫃檯買賣中心</dd>
      <dt class="font-semibold text-gray-600">公司名稱</dt>
      <dd>寶得利國際股份有限公司</dd>
      <dt class="font-semibold text-gray-600">股票代號</dt>
      <dd class="font-bold text-primary">5301</dd>
      <dt class="font-semibold text-gray-600">產業</dt>
      <dd>觀光產業</dd>
      <dt class="font-semibold text-gray-600">上櫃日期</dt>
      <dd>1990/6/1</dd>
      <dt class="font-semibold text-gray-600">公司地址</dt>
      <dd>台北市中山區新生北路二段28巷1號B1</dd>
      <dt class="font-semibold text-gray-600">電話</dt>
      <dd>+886-2-8921-1333</dd>
      <dt class="font-semibold text-gray-600">傳真</dt>
      <dd>+886-2-8921-0333</dd>
    </dl>
  </section>

  <section class="mb-10">
    <h4 class="text-xl font-bold text-primary mb-4 border-b border-gold/30 pb-2">股票報價資訊</h4>
    <p>
      <a href="http://mis.twse.com.tw/stock/index.jsp" target="_blank" class="text-gold hover:underline"
        >http://mis.twse.com.tw/stock/index.jsp</a
      >
    </p>
  </section>

  <section class="mb-10">
    <h4 class="text-xl font-bold text-primary mb-4 border-b border-gold/30 pb-2">股務代理</h4>
    <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-2 text-base">
      <dt class="font-semibold text-gray-600">公司</dt>
      <dd>元大證券股份有限公司</dd>
      <dt class="font-semibold text-gray-600">地址</dt>
      <dd>台北市大安區敦化南路二段67號B1</dd>
      <dt class="font-semibold text-gray-600">電話</dt>
      <dd>+886-2-25865859</dd>
      <dt class="font-semibold text-gray-600">網址</dt>
      <dd>
        <a href="https://www.yuanta.com.tw" target="_blank" class="text-gold hover:underline"
          >https://www.yuanta.com.tw</a
        >
      </dd>
    </dl>
  </section>

  <section>
    <h4 class="text-xl font-bold text-primary mb-6 border-b border-gold/30 pb-2">聯絡窗口</h4>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-lg border border-gray-200 p-5">
        <h5 class="font-bold text-primary mb-3">股務室</h5>
        <div class="space-y-1 text-sm text-gray-700">
          <p>台北市中山區新生北路二段28巷1號B1</p>
          <p>+886-2-8921-1333 分機588</p>
        </div>
      </div>
      <div class="rounded-lg border border-gray-200 p-5">
        <h5 class="font-bold text-primary mb-3">投資人關係及利害關係人</h5>
        <div class="space-y-1 text-sm text-gray-700">
          <p>台北市中山區新生北路二段28巷1號B1</p>
          <p>+886-2-8921-1333 分機788 寧先生</p>
          <p>
            <a href="mailto:ning@cjwtaiwan.com" class="text-gold hover:underline">ning@cjwtaiwan.com</a>
          </p>
        </div>
      </div>
      <div class="rounded-lg border border-gray-200 p-5">
        <h5 class="font-bold text-primary mb-3">股東帳戶及過戶轉讓</h5>
        <div class="space-y-1 text-sm text-gray-700">
          <p>元大證券股份有限公司</p>
          <p>台北市大安區敦化南路二段67號B1</p>
        </div>
      </div>
    </div>
  </section>
</SubPageLayout>
