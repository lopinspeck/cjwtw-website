---
import SubPageLayout from '../components/SubPageLayout.astro';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'hr', label: '人力資源', href: `${base}hr` },
  { id: 'career', label: '人才招募', href: `${base}career` },
  { id: 'csr-report', label: '報告書下載', href: `${base}csr-report` },
];
---

<SubPageLayout title="人力資源" titleEn="CSR" titleTw="企業社會責任" menuItems={menuItems} activeId="hr">
  <p>
    &nbsp;&nbsp; &nbsp; &nbsp; &nbsp;<span style="font-size:10.0pt"
      ><span style="font-family:'新細明體','serif'">&amp;</span></span>
  </p>
</SubPageLayout>
