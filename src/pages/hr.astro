---
import SubPageLayout from '../components/SubPageLayout.astro';
import { langData } from '../data/lang.js';
import { decodeHtml } from '../data/decode.js';
import pagesData from '../data/pages.json';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'hr', label: langData[11].tw, href: `${base}hr` },
  { id: 'career', label: langData[12].tw, href: `${base}career` },
  { id: 'csr-report', label: langData[13].tw, href: `${base}csr-report` },
];

const pageContent = pagesData['hr.html'];
const contentHtml = pageContent ? decodeHtml(pageContent.a_text_tw) : '<p>人力資源相關資訊</p>';
---

<SubPageLayout
  title="人力資源"
  titleEn="CSR"
  titleTw="企業社會責任"
  menuItems={menuItems}
  activeId="hr"
>
  <div set:html={contentHtml} />
</SubPageLayout>
