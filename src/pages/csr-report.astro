---
import SubPageLayout from '../components/SubPageLayout.astro';
import { langData, csrData } from '../data/lang.js';

const base = import.meta.env.BASE_URL;
const menuItems = [
  { id: 'hr', label: langData[11].tw, href: `${base}hr` },
  { id: 'career', label: langData[12].tw, href: `${base}career` },
  { id: 'csr-report', label: langData[13].tw, href: `${base}csr-report` },
];
---

<SubPageLayout
  title="報告書下載"
  titleEn="CSR"
  titleTw="企業社會責任"
  menuItems={menuItems}
  activeId="csr-report"
  pageClass="csr_page"
>
  <div class="space-y-6">
    {
      Object.entries(csrData).map(([id, item]) => (
        <div class="flex items-center gap-4 p-6 bg-gray-50 rounded-lg">
          <div class="w-16 h-20 bg-primary/10 rounded flex items-center justify-center">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-primary">{item.tw}</h3>
            <span class="text-sm text-primary/50">{langData[23].tw}</span>
          </div>
        </div>
      ))
    }
  </div>
</SubPageLayout>
