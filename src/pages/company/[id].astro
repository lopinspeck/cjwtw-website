---
import SubPageLayout from '../../components/SubPageLayout.astro';
import { comData } from '../../data/lang.js';
import { decodeHtml } from '../../data/decode.js';
import pagesData from '../../data/pages.json';

export function getStaticPaths() {
  return Object.keys(comData).map((key) => ({ params: { id: key } }));
}

const base = import.meta.env.BASE_URL;
const { id } = Astro.params;
const menuItems = Object.entries(comData).map(([key, val]) => ({
  id: key,
  label: val.tw,
  href: `${base}company/${key}`,
}));

// 資料來源為本地靜態 pages.json，內容已受信任
const pageContent = pagesData[`company-${id}.html`];
const contentHtml = pageContent ? decodeHtml(pageContent.c_text_tw) : '';
---

<SubPageLayout
  title={comData[id]?.tw}
  titleEn="Corporate Governance"
  titleTw="公司治理"
  menuItems={menuItems}
  activeId={id}
>
  <div set:html={contentHtml} />
</SubPageLayout>
