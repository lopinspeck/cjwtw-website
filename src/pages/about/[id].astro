---
import SubPageLayout from '../../components/SubPageLayout.astro';
import { aboutData } from '../../data/lang.js';
import { decodeHtml } from '../../data/decode.js';
import pagesData from '../../data/pages.json';

export function getStaticPaths() {
  return Object.keys(aboutData).map((key) => ({ params: { id: key } }));
}

const base = import.meta.env.BASE_URL;
const { id } = Astro.params;
const menuItems = Object.entries(aboutData).map(([key, val]) => ({
  id: key,
  label: val.tw,
  href: `${base}about/${key}`,
}));

// 資料來源為本地靜態 pages.json，內容已受信任
const pageContent = pagesData[`about-${id}.html`];
const contentHtml = pageContent ? decodeHtml(pageContent.a_text_tw) : '';
---

<SubPageLayout
  title={aboutData[id]?.tw}
  titleEn="About CJW"
  titleTw="關於寶得利"
  menuItems={menuItems}
  activeId={id}
>
  <div set:html={contentHtml} />
</SubPageLayout>
