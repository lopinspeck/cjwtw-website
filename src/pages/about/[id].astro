---
import SubPageLayout from '../../components/SubPageLayout.astro';
import { aboutData } from '../../data/lang.js';
import { decodeHtml } from '../../data/decode.js';
import pagesData from '../../data/pages.json';

export function getStaticPaths() {
  return [
    { params: { id: '2' } },
    { params: { id: '4' } },
    { params: { id: '5' } },
    { params: { id: '7' } },
  ];
}

const { id } = Astro.params;
const menuItems = Object.entries(aboutData).map(([key, val]) => ({
  id: key,
  label: val.tw,
  href: `/about/${key}`,
}));

// Get page content
const fileMap = { '2': 'about-2.html', '4': 'about-4.html', '5': 'about-5.html', '7': 'about-7.html' };
const pageContent = pagesData[fileMap[id]];
const contentHtml = pageContent ? decodeHtml(pageContent.a_text_tw) : '';
---

<SubPageLayout
  title={aboutData[id]?.tw}
  titleEn="About CJW"
  titleTw="關於寶得利"
  menuItems={menuItems}
  activeId={id}
>
  <div set:html={contentHtml} />
</SubPageLayout>
